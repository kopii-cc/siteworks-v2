---
interface Props {
  title: string;
  description?: string;
}
const { title, description = "Limestone retaining walls, earthworks, bobcat & site preparation in Perth, Western Australia." } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Mitchell Siteworks</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />
</head>
<body>
  <nav>
    <a href="/" class="logo">Mitchell Siteworks</a>
    <button class="menu-toggle" aria-label="Menu">☰</button>
    <ul class="nav-links">
      <li><a href="/">Home</a></li>
      <li><a href="/services">Services</a></li>
      <li><a href="/about">About</a></li>
      <li><a href="/contact">Contact</a></li>
    </ul>
  </nav>

  <main><slot /></main>

  <footer>
    <div class="footer-content">
      <div class="footer-brand">
        <h3>Mitchell Siteworks</h3>
        <p>Limestone · Earthworks · Site Preparation</p>
      </div>
      <div class="footer-links">
        <a href="/services">Services</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </div>
      <p class="footer-copy">© 2026 Mitchell Siteworks · Perth, Western Australia · Licensed & Insured</p>
    </div>
  </footer>

  <script>
    document.querySelector('.menu-toggle')?.addEventListener('click', () => {
      document.querySelector('.nav-links')?.classList.toggle('open');
    });
  </script>
</body>
</html>

<style is:global>
  :root {
    --stone: #5c5248;
    --rust: #b5651d;
    --limestone: #d4c5a9;
    --cream: #f5f0e8;
    --dark: #2a2520;
    --light: #faf8f4;
    --text: #3a3530;
    --text-light: #7a7268;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: 'Lato', sans-serif;
    background: var(--light);
    color: var(--text);
    line-height: 1.7;
  }
  h1,h2,h3,h4 { font-family: 'Oswald', sans-serif; text-transform: uppercase; letter-spacing: 0.05em; }
  a { color: var(--rust); text-decoration: none; transition: color 0.2s; }
  a:hover { color: var(--stone); }

  nav {
    display: flex; align-items: center; justify-content: space-between;
    padding: 1rem 2rem;
    background: var(--dark);
    position: sticky; top: 0; z-index: 100;
  }
  .logo { font-family: 'Oswald', sans-serif; font-size: 1.4rem; font-weight: 700; color: var(--limestone); letter-spacing: 0.1em; }
  .nav-links { display: flex; gap: 2rem; list-style: none; }
  .nav-links a { color: rgba(255,255,255,0.8); font-size: 0.9rem; font-weight: 400; text-transform: uppercase; letter-spacing: 0.08em; }
  .nav-links a:hover { color: var(--limestone); }
  .menu-toggle { display: none; background: none; border: none; color: white; font-size: 1.5rem; cursor: pointer; }

  main { min-height: 70vh; }

  footer { background: var(--dark); color: rgba(255,255,255,0.7); padding: 3rem 2rem 2rem; }
  .footer-brand h3 { color: var(--limestone); font-size: 1.5rem; margin-bottom: 0.3rem; }
  .footer-links { display: flex; gap: 2rem; justify-content: center; margin: 1.5rem 0; flex-wrap: wrap; }
  .footer-links a { color: rgba(255,255,255,0.6); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.1em; }
  .footer-links a:hover { color: var(--limestone); }
  .footer-copy { font-size: 0.78rem; opacity: 0.5; text-align: center; }

  @media (max-width: 768px) {
    .menu-toggle { display: block; }
    .nav-links { display: none; flex-direction: column; position: absolute; top: 100%; left: 0; right: 0; background: var(--dark); padding: 1rem; gap: 0.8rem; }
    .nav-links.open { display: flex; }
  }

  .btn { display: inline-block; padding: 0.8rem 2rem; background: var(--rust); color: white; border-radius: 3px; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; font-size: 0.9rem; transition: background 0.2s, transform 0.2s; }
  .btn:hover { background: var(--stone); color: white; transform: translateY(-1px); }
  .btn-outline { background: transparent; border: 2px solid var(--rust); color: var(--rust); }
  .btn-outline:hover { background: var(--rust); color: white; }
</style>