---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
  <section class="hero">
    <div class="hero-content">
      <p class="tag">Perth's Trusted Earthworks Experts</p>
      <h1>Site Preparation<br/>Done Right</h1>
      <p class="sub">Limestone retaining walls · Bulk earthworks · Bobcat & site clearing · Drainage solutions</p>
      <div class="hero-cta">
        <a href="/contact" class="btn">Get a Free Quote</a>
        <a href="/services" class="btn btn-outline">Our Services</a>
      </div>
    </div>
  </section>

  <section class="intro">
    <div class="container">
      <h2>Built on Rock Solid Work</h2>
      <p>From small residential jobs to large-scale commercial site preparation, Mitchell Siteworks has the experience, equipment and know-how to get your site ready — on time and on budget.</p>
      <p>We service all of Perth and the surrounding areas, from the hills to the coast.</p>
    </div>
  </section>

  <section class="services-grid">
    <div class="container">
      <h2>What We Do</h2>
      <div class="cards">
        <div class="card">
          <div class="card-icon">🧱</div>
          <h3>Limestone Retaining Walls</h3>
          <p>Natural limestone retaining walls built to last — from garden edges to major structural walls. Clean stone, professional finish, no mess left behind.</p>
          <a href="/services#retaining">Learn More →</a>
        </div>
        <div class="card">
          <div class="card-icon">🚜</div>
          <h3>Bulk Earthworks</h3>
          <p>Site cuts, fill, grading and levelling. We move the earth so you don't have to worry about what's underneath before you build.</p>
          <a href="/services#earthworks">Learn More →</a>
        </div>
        <div class="card">
          <div class="card-icon">�🦴</div>
          <h3>Bobcat & Site Clearing</h3>
          <p>Fast, efficient bobcat work for site clearing, rubble removal, material spreading and access tracks. No job too small.</p>
          <a href="/services#bobcat">Learn More →</a>
        </div>
        <div class="card">
          <div class="card-icon">💧</div>
          <h3>Drainage & Site Prep</h3>
          <p>Proper drainage solutions, spoon drains, and subsoil preparation. Get your site draining right the first time.</p>
          <a href="/services#drainage">Learn More →</a>
        </div>
      </div>
    </div>
  </section>

  <section class="why-us">
    <div class="container">
      <h2>Why Choose Mitchell Siteworks?</h2>
      <div class="features">
        <div class="feature">
          <h3>Licensed & Insured</h3>
          <p>Full liability coverage and compliance with all local council requirements. Peace of mind on every job.</p>
        </div>
        <div class="feature">
          <h3>Own Equipment</h3>
          <p>We run our own fleet — no subcontracting, no delays. When we say we'll be there, we're there.</p>
        </div>
        <div class="feature">
          <h3>Free Quotes</h3>
          <p>Honest, no-obligation quotes. We tell you what the job costs upfront — no hidden fees, no surprises.</p>
        </div>
        <div class="feature">
          <h3>Clean & Tidy</h3>
          <p>We leave every site clean and safe. Rubble removed, access clear, ready for the next trade.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="cta">
    <div class="container">
      <h2>Ready to Get Started?</h2>
      <p>Get in touch for a free, no-obligation quote. No job too big or too small.</p>
      <a href="/contact" class="btn">Request a Quote</a>
    </div>
  </section>
</Layout>

<style>
.hero {
  background: linear-gradient(135deg, #2a2520 0%, #4a3f35 60%, #5c5248 100%);
  color: white; padding: 8rem 2rem 5rem; text-align: center;
  position: relative; overflow: hidden;
}
.hero::before {
  content: ''; position: absolute; inset: 0;
  background: radial-gradient(ellipse at 80% 50%, rgba(181,101,29,0.2) 0%, transparent 60%);
}
.hero-content { position: relative; max-width: 750px; margin: 0 auto; }
.tag { color: var(--limestone); text-transform: uppercase; letter-spacing: 0.2em; font-size: 0.85rem; font-weight: 700; margin-bottom: 1rem; }
h1 { font-size: clamp(2.8rem, 7vw, 5rem); font-weight: 700; line-height: 1.05; margin-bottom: 1.2rem; color: white; }
.sub { font-size: 1.05rem; opacity: 0.75; margin-bottom: 2.5rem; font-weight: 300; }
.hero-cta { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

.container { max-width: 1100px; margin: 0 auto; padding: 0 2rem; }

.intro { padding: 5rem 0; text-align: center; background: white; }
.intro h2 { font-size: 2.2rem; color: var(--stone); margin-bottom: 1.2rem; }
.intro p { max-width: 680px; margin: 0 auto 1rem; color: var(--text-light); font-size: 1.02rem; }

.services-grid { padding: 5rem 0; background: var(--cream); }
.services-grid h2 { font-size: 2.2rem; color: var(--stone); text-align: center; margin-bottom: 3rem; }
.cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.5rem; }
.card { background: white; border-radius: 6px; padding: 2rem; border-top: 3px solid var(--rust); }
.card-icon { font-size: 2.5rem; margin-bottom: 0.8rem; }
.card h3 { font-size: 1.3rem; color: var(--dark); margin-bottom: 0.7rem; }
.card p { font-size: 0.92rem; color: var(--text-light); margin-bottom: 1rem; line-height: 1.6; }
.card a { color: var(--rust); font-weight: 700; font-size: 0.88rem; text-transform: uppercase; letter-spacing: 0.05em; }

.why-us { padding: 5rem 0; background: white; }
.why-us h2 { font-size: 2.2rem; color: var(--stone); text-align: center; margin-bottom: 3rem; }
.features { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 2rem; }
.feature h3 { font-size: 1.1rem; color: var(--rust); margin-bottom: 0.5rem; }
.feature p { font-size: 0.92rem; color: var(--text-light); }

.cta { background: var(--stone); color: white; text-align: center; padding: 5rem 2rem; }
.cta h2 { font-size: 2.5rem; color: white; margin-bottom: 1rem; }
.cta p { margin-bottom: 2rem; opacity: 0.8; }
</style>